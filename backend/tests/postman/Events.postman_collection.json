		{
			"name": "GetEvents",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", () => {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"const jsonData = pm.response.json();",
							"",
							"pm.test(\"Response contains events and metadata\", () => {",
							"    pm.expect(jsonData).to.have.property('events').and.be.an('array');",
							"    pm.expect(jsonData).to.have.property('metadata').and.be.an('object');",
							"});",
							"",
							"pm.test(\"Metadata matches the requested pagination\", () => {",
							"    const expectedPage = parseInt(pm.collectionVariables.get(\"page\")) || 1;",
							"    const expectedPageSize = parseInt(pm.collectionVariables.get(\"pageSize\")) || 2;",
							"    ",
							"    pm.expect(jsonData.metadata.page).to.eql(expectedPage);",
							"    pm.expect(jsonData.metadata.pageSize).to.eql(expectedPageSize);",
							"    pm.expect(jsonData.events.length).to.be.at.most(expectedPageSize);",
							"});",
							"",
							"pm.test(\"Events fall within the requested date range\", () => {",
							"    const startVar = pm.collectionVariables.get(\"startDate\");",
							"    const endVar = pm.collectionVariables.get(\"endDate\");",
							"",
							"    if (startVar && endVar) {",
							"        const startDate = new Date(startVar);",
							"        const endDate = new Date(endVar);",
							"",
							"        jsonData.events.forEach(event => {",
							"            const eventDate = new Date(event.dateVenueUtc);",
							"            ",
							"            pm.expect(eventDate.getTime()).to.be.at.least(startDate.getTime(), ",
							"                `Event ${event.id} (${event.dateVenueUtc}) is before startDate`);",
							"            pm.expect(eventDate.getTime()).to.be.at.most(endDate.getTime(), ",
							"                `Event ${event.id} (${event.dateVenueUtc}) is after endDate`);",
							"        });",
							"    }",
							"});",
							"",
							"pm.test(\"List view should only contain IDs, not hydrated objects\", () => {",
							"    if (jsonData.events.length > 0) {",
							"        const firstEvent = jsonData.events[0];",
							"        pm.expect(firstEvent).to.have.property('homeTeamId');",
							"        pm.expect(firstEvent).to.not.have.property('homeTeam');",
							"    }",
							"});",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
