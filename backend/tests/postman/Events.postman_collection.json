		{
			"name": "AddEvent",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201 or 200\", () => {",
							"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
							"});",
							"",
							"const jsonData = pm.response.json();",
							"const requestBody = JSON.parse(pm.request.body.raw);",
							"",
							"pm.test(\"Response includes a valid New Event ID\", () => {",
							"    pm.expect(jsonData.id).to.be.a('string').and.not.empty;",
							"});",
							"",
							"pm.test(\"Core event data matches the request\", () => {",
							"    pm.expect(jsonData.name).to.eql(requestBody.name);",
							"    pm.expect(jsonData.season).to.eql(requestBody.season);",
							"    pm.expect(jsonData.status).to.eql(requestBody.status.toLowerCase());",
							"});",
							"",
							"pm.test(\"Score totals are correctly calculated from period scores\", () => {",
							"    const expectedHomeTotal = requestBody.result.periodScores.reduce((a, b) => a + b.homeScore, 0);",
							"    const expectedAwayTotal = requestBody.result.periodScores.reduce((a, b) => a + b.awayScore, 0);",
							"    ",
							"    pm.expect(jsonData.result.homeScore).to.eql(expectedHomeTotal);",
							"    pm.expect(jsonData.result.awayScore).to.eql(expectedAwayTotal);",
							"});",
							"",
							"pm.test(\"All match incidents were recorded\", () => {",
							"    pm.expect(jsonData.result.matchIncidents.length).to.eql(requestBody.result.incidents.length);",
							"    ",
							"    const firstReqType = requestBody.result.incidents[0].type.toLowerCase();",
							"    const firstResType = jsonData.result.matchIncidents[0].type;",
							"    pm.expect(firstResType).to.eql(firstReqType);",
							"});",
							"",
							"pm.test(\"Audit timestamps were generated\", () => {",
							"    pm.expect(jsonData.createdAtUtc).to.not.be.null;",
							"    pm.expect(jsonData.result.createdAtUtc).to.not.be.null;",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
