	"item": [
		{
			"name": "GetEventById",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", () => {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"const jsonData = pm.response.json();",
							"",
							"pm.test(\"Response contains all essential nested objects\", () => {",
							"    pm.expect(jsonData).to.have.property('homeTeam');",
							"    pm.expect(jsonData).to.have.property('awayTeam');",
							"    pm.expect(jsonData).to.have.property('competition');",
							"});",
							"",
							"pm.test(\"Returned Event ID matches the requested ID\", () => {",
							"    const expectedId = pm.collectionVariables.get(\"eventId\");",
							"    pm.expect(jsonData.id).to.eql(expectedId);",
							"});",
							"",
							"pm.test(\"Cross-Entity SportId consistency check\", () => {",
							"    const targetSportId = jsonData.competition.sportId;",
							"    ",
							"    pm.expect(jsonData.homeTeam.sportId).to.eql(targetSportId, \"Home Team SportId mismatch\");",
							"    pm.expect(jsonData.awayTeam.sportId).to.eql(targetSportId, \"Away Team SportId mismatch\");",
							"});",
							"",
							"pm.test(\"WinnerId must match either Home or Away Team ID\", () => {",
							"    if (jsonData.result && jsonData.result.winnerId) {",
							"        const teamIds = [jsonData.homeTeam.id, jsonData.awayTeam.id];",
							"        pm.expect(teamIds).to.include(jsonData.result.winnerId);",
							"    }",
							"});",
							"",
							"pm.test(\"Total scores match the sum of period scores\", () => {",
							"    if (jsonData.result && jsonData.result.periodScores) {",
							"        const calculatedHomeScore = jsonData.result.periodScores.reduce((acc, p) => acc + p.homeScore, 0);",
							"        const calculatedAwayScore = jsonData.result.periodScores.reduce((acc, p) => acc + p.awayScore, 0);",
							"        ",
							"        pm.expect(jsonData.result.homeScore).to.eql(calculatedHomeScore, \"Home score aggregation error\");",
							"        pm.expect(jsonData.result.awayScore).to.eql(calculatedAwayScore, \"Away score aggregation error\");",
							"    }",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
