# Template for local development. Copy to .env and fill in.
DB_SERVER=localhost
DB_NAME=SportsCalendar
DB_USER=sa
DB_PASSWORD=
DB_PORT=1433

# Connection String
CONNECTION_STRING=Server=${DB_SERVER},${DB_PORT};Database=${DB_NAME};User Id=${DB_USER};Password=${DB_PASSWORD};TrustServerCertificate=True;
